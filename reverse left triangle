using System;
namespace Stars
{
    class triangle
    {
        public static void Main()
        {
            Console.WriteLine("Enter a number:");
            int n= Convert.ToInt32(Console.ReadLine());
            for(int i=0;i<n;i++)
            {
                for(int j=i;j<n;j++)
                {
                    Console.Write("* ");
                }
                Console.WriteLine();
            }
        }
    }
}
