using System;
namespace Stars
{
    class triangle
    {
        public static void Main()
        {
            Console.WriteLine("Enter a number:");
            int n= Convert.ToInt32(Console.ReadLine());
            for(int i=0;i<n;i++)
            {
                for(int j=0;j<=i;j++)
                {
                    char letter = (char)(65+j);
                    Console.Write(letter+" ");
                }
                Console.WriteLine();
            }
        }
    }
}
